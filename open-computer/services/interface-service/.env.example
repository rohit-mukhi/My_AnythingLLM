# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=
# CONTEXT_WINDOW=
# ENABLE_PARALLEL_TOOL_CALLS=

# Set to true/1/yes/on to bypass prompt preflight and plan approval.
# SKIP_PLANNING=false

# off disables subagent routing, explicit only delegates when the prompt asks for it,
# auto lets preflight choose sequential delegation.
# SUBAGENTS_MODE=auto

# Keep child subagents sequential by default for local providers.
# PARALLEL_SUBAGENTS=false

# For local dev: copy this file to services/server/.env and fill in your values.
#
# Per-agent overrides: drop a .env in agents/<name>/.env and `open-computer up` will
# push it into the VM as /home/agent/agent.env. Values there override this file
# on boot; vars set externally (e.g. systemd PORT) are still respected.
# No agent .env is created by default — write one manually when you need it.